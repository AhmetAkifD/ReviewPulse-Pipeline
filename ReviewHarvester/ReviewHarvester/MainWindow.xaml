<Window x:Class="ReviewHarvester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReviewHarvester"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBox x:Name="TxtUrl" Padding="8" FontSize="14" VerticalContentAlignment="Center"/>

            <TextBlock IsHitTestVisible="False" 
               Text="Site adresini buraya yapıştır..." 
               VerticalAlignment="Center" 
               HorizontalAlignment="Left" 
               Margin="12,0,0,0" 
               Foreground="DarkGray">
                <TextBlock.Style>
                    <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=TxtUrl}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Button x:Name="BtnStart" Content="Hasadı Başlat" Width="120" Height="35" Click="BtnStart_Click" Background="#2ecc71" Foreground="White" FontWeight="Bold"/>
            <ProgressBar x:Name="PrgStatus" Width="300" Height="20" Margin="15,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <ListView Grid.Row="2" x:Name="LstReviews">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Kullanıcı" DisplayMemberBinding="{Binding User}" Width="100"/>
                    <GridViewColumn Header="Puan" DisplayMemberBinding="{Binding Rating}" Width="50"/>
                    <GridViewColumn Header="Yorum" DisplayMemberBinding="{Binding Comment}" Width="400"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StatusBar Grid.Row="3" Background="Transparent" Margin="0,10,0,0">
            <TextBlock x:Name="TxtStatus" Text="Hazır." Foreground="Gray"/>
        </StatusBar>
    </Grid>
</Window>
