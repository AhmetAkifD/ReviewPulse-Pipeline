<Window x:Class="ReviewHarvester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReviewHarvester"
        mc:Ignorable="d"
        Title="ReviewHarvester - Hasat Merkezi" Height="500" Width="850">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="ReviewHarvester - Bağlantı Ayarları" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="BtnLoadTxt" Content="TXT Dosyası Seç" Width="140" Height="35" Click="BtnLoadTxt_Click" Background="#8e44ad" Foreground="White" FontWeight="Bold" Margin="0,0,10,0"/>

                <TextBox Grid.Column="1" x:Name="TxtUrl" Padding="8" FontSize="14" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Column="1" IsHitTestVisible="False" Text="Tek ürün linki girin veya soldaki butondan TXT yükleyin..." VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,0,0,0" Foreground="DarkGray">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=TxtUrl}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Button x:Name="BtnStart" Content="Hasadı Başlat" Width="120" Height="35" Click="BtnStart_Click" Background="#2ecc71" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="BtnCsvManager" Content="CSV Yöneticisi" Width="120" Height="35" Margin="10,0,0,0" Click="BtnCsvManager_Click" Background="#3498db" Foreground="White" FontWeight="Bold"/>

            <ProgressBar x:Name="PrgStatus" Width="300" Height="20" Margin="15,0,15,0" VerticalAlignment="Center"/>
            <Button x:Name="BtnSave" Content="Kaydet" Width="120" Height="35" HorizontalAlignment="Right" Click="BtnSave_Click" Background="#e67e22" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

        <ListView Grid.Row="2" x:Name="LstReviews" ItemsSource="{Binding HarvestedReviews}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Kullanıcı" DisplayMemberBinding="{Binding User}" Width="100"/>
                    <GridViewColumn Header="Puan" DisplayMemberBinding="{Binding Rating}" Width="50"/>
                    <GridViewColumn Header="Yorum" DisplayMemberBinding="{Binding Comment}" Width="550"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StatusBar Grid.Row="3" Background="Transparent" Margin="0,10,0,0">
            <TextBlock x:Name="TxtStatus" Text="Hazır." Foreground="Gray"/>
        </StatusBar>
    </Grid>
</Window>