<Window x:Class="ReviewHarvester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ReviewHarvester" Height="600" Width="1000"
        Background="{DynamicResource PrimaryBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.Resources>
            <Style TargetType="{x:Type GridViewColumnHeader}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource SecondaryBrush}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Padding" Value="5,8"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SecondaryBrush}"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>
            <Style TargetType="{x:Type ListViewItem}">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListViewItem}">
                            <Border x:Name="Bd" CornerRadius="5" Background="{TemplateBinding Background}" Padding="5">
                                <GridViewRowPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="{x:Type Button}">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="true">
                                    <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="true">
                                    <Setter TargetName="border" Property="Opacity" Value="0.70"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="false">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Padding" Value="15,10"/>
                <Setter Property="Margin" Value="10,5"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="true">
                                    <Setter TargetName="border" Property="Background" Value="#1AFFFFFF"/>
                                    <Setter Property="Foreground" Value="{DynamicResource SecondaryBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0A000000" BorderBrush="{DynamicResource SecondaryBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,30,0,20">
                    <TextBlock Text="Review" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Harvester" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource SecondaryBrush}" HorizontalAlignment="Center" Margin="0,-5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="BtnNavScraper" Content="🔍  Scraping Merkezi" Style="{StaticResource SidebarButtonStyle}" Click="BtnNavScraper_Click"/>
                    <Button x:Name="BtnNavCsv" Content="📂  CSV Yöneticisi" Style="{StaticResource SidebarButtonStyle}" Click="BtnNavCsv_Click"/>
                </StackPanel>

                <Button Grid.Row="2" x:Name="BtnThemeToggle" Click="BtnThemeToggle_Click"
                        Height="45" Margin="15,0,15,20" Background="#1AFFFFFF" Foreground="{DynamicResource TextBrush}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TxtThemeIcon" Text="🌙" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Tema Değiştir" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="25">

            <Grid x:Name="PageScraper" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Scraping Merkezi" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,15"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" x:Name="BtnLoadTxt" Content="TXT Yükle" Width="120" Height="40" 
                                Click="BtnLoadTxt_Click" Background="{DynamicResource SecondaryBrush}" Margin="0,0,12,0"/>

                        <TextBox Grid.Column="1" x:Name="TxtUrl" Padding="12,8" FontSize="14" VerticalContentAlignment="Center" 
                                 Background="#1AFFFFFF" Foreground="{DynamicResource TextBrush}" BorderThickness="1" 
                                 BorderBrush="{DynamicResource SecondaryBrush}"/>
                        <TextBlock Grid.Column="1" IsHitTestVisible="False" Text="Link giriniz" 
                                   VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0" Foreground="Gray" Opacity="0.8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=TxtUrl}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,20">

                    <TextBlock Text="Puan Filtresi" 
                       Foreground="{DynamicResource TextBrush}" 
                       FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox x:Name="Chk1" Content="1 ⭐" IsChecked="True" Foreground="{DynamicResource TextBrush}" Margin="0,0,15,0"/>
                            <CheckBox x:Name="Chk2" Content="2 ⭐" IsChecked="True" Foreground="{DynamicResource TextBrush}" Margin="0,0,15,0"/>
                            <CheckBox x:Name="Chk3" Content="3 ⭐" IsChecked="True" Foreground="{DynamicResource TextBrush}" Margin="0,0,15,0"/>
                            <CheckBox x:Name="Chk4" Content="4 ⭐" IsChecked="True" Foreground="{DynamicResource TextBrush}" Margin="0,0,15,0"/>
                            <CheckBox x:Name="Chk5" Content="5 ⭐" IsChecked="True" Foreground="{DynamicResource TextBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="Sadece Olumsuzlar" Click="BtnSelectNegative_Click" 
                            Width="140" Height="30" Margin="0,0,10,0"
                            Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource PrimaryBrush}" FontSize="12"/>
                            <Button Content="Sadece Olumlular" Click="BtnSelectPositive_Click" 
                            Width="140" Height="30"
                            Background="{DynamicResource SecondaryBrush}" Foreground="{DynamicResource PrimaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button x:Name="BtnStart" Content="▶" Width="65" Height="40" Margin="0,0,10,0" 
                                Click="BtnStart_Click" Background="{DynamicResource SecondaryBrush}" ToolTip="Hasadı Başlat" FontSize="20"/>

                            <Button x:Name="BtnStop" Content="⏹" Width="65" Height="40" 
                                Click="BtnStop_Click" Background="{DynamicResource AccentBrush}" ToolTip="Durdur" IsEnabled="False" FontSize="20"/>
                        </StackPanel>

                        <ProgressBar Grid.Column="1" x:Name="PrgStatus" Height="8" Margin="20,0" VerticalAlignment="Center" 
                             Foreground="{DynamicResource SecondaryBrush}" Background="#1AFFFFFF" BorderThickness="0"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <ComboBox x:Name="CmbSpeed" Width="130" Height="40" Margin="0,0,15,0" SelectedIndex="0"
                                    VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                    Background="{DynamicResource PrimaryBrush}" Foreground="{DynamicResource TextBrush}" 
                                    BorderThickness="1" BorderBrush="{DynamicResource SecondaryBrush}">

                                <ComboBox.Resources>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1AFFFFFF"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SecondaryBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource SecondaryBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.Resources>

                                <ComboBoxItem Content="Normal (2 sn)"/>
                                <ComboBoxItem Content="İnsan Gibi (4 sn)"/>
                            </ComboBox>

                            <Button x:Name="BtnSaveJson" Content="JSON Kaydet" Width="100" Height="40" Margin="0,0,10,0"
                                Click="BtnSaveJson_Click" Background="{DynamicResource SecondaryBrush}" Foreground="{DynamicResource PrimaryBrush}"/>

                            <Button x:Name="BtnSave" Content="CSV Kaydet" Width="100" Height="40" 
                                Click="BtnSave_Click" Background="{DynamicResource AccentBrush}"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>

                <ListView Grid.Row="2" x:Name="LstReviews" ItemsSource="{Binding HarvestedReviews}" Background="Transparent" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Kullanıcı" DisplayMemberBinding="{Binding User}" Width="120"/>
                            <GridViewColumn Header="Puan" DisplayMemberBinding="{Binding Rating}" Width="60"/>
                            <GridViewColumn Header="Yorum" DisplayMemberBinding="{Binding Comment}" Width="500"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <StatusBar Grid.Row="3" Background="Transparent" Margin="0,15,0,0">
                    <TextBlock x:Name="TxtStatus" Text="Sistem Hazır." Foreground="{DynamicResource TextBrush}" Opacity="0.6"/>
                </StatusBar>
            </Grid>

            <Grid x:Name="PageCsvManager" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="CSV Yöneticisi ve Birleştirme" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,15"/>
                    <TextBlock Text="Farklı zamanlarda çektiğiniz veya farklı kategorilere ait olan CSV dosyalarını burada birleştirebilirsiniz. Ctrl tuşuna basılı tutarak birden fazla dosya seçebilirsiniz." 
                               Foreground="Gray" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,20"/>

                    <Button x:Name="BtnMergeCsv" Content="Dosyaları Seç ve Birleştir" Width="220" Height="40" 
                            HorizontalAlignment="Left" Click="BtnMergeCsv_Click" 
                            Background="{DynamicResource SecondaryBrush}"/>
                </StackPanel>
            </Grid>

        </Grid>
    </Grid>
</Window>