<Window x:Class="ReviewHarvester.CsvManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReviewHarvester"
        mc:Ignorable="d"
        Title="CsvManagerWindow" Height="450" Width="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnLoadCsv" Content="CSV Dosyaları Seç" Width="130" Height="30" Click="BtnLoadCsv_Click" Background="#34495e" Foreground="White"/>
            <Button x:Name="BtnMergeCsv" Content="Birleştir ve Kaydet" Width="130" Height="30" Margin="10,0,0,0" Click="BtnMergeCsv_Click" Background="#27ae60" Foreground="White" IsEnabled="False"/>
            <TextBlock x:Name="TxtInfo" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="Gray" Text="Seçilen dosya yok."/>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="DgdPreview" AutoGenerateColumns="True" IsReadOnly="True" AlternatingRowBackground="#f2f2f2"/>

        <TextBlock Grid.Row="2" Text="Not: Python NLP aşamasına geçmeden önce verilerinizi burada tek bir 'Master CSV' dosyasında birleştirebilirsiniz." 
                   FontStyle="Italic" Foreground="Gray" Margin="0,10,0,0"/>
    </Grid>
</Window>
